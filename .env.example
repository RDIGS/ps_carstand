# Ligação ao Postgres (DB Central + todos os schemas de stand vivem na mesma instância)
DATABASE_URL=postgresql://user:pass@localhost:5432/ps_carstand

# Google Gemini (OCR do DUA)
GEMINI_API_KEY=
# "gemini-3-flash" (secção 14) só existe como "-preview" na API real e esteve
# instável em teste (503 sobrecarregado); "gemini-3.1-flash-lite" está
# confirmado a responder bem — troca aqui sem precisar de nova versão da app.
GEMINI_MODEL=gemini-3.1-flash-lite

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_EXPIRES_IN=2592000

# Supabase (Storage — só documentos gerados, ex. Registo de Compra em PDF).
# SUPABASE_URL é o "Project URL" em Settings → API — NÃO o endpoint S3-compatible
# (esse tem outro formato/protocolo e não funciona com este código).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Bucket privado — guarda PDFs gerados (Registo de Compra, identificação do
# comprador) e fotos de identificação/DUA (image/jpeg, image/png) quando o
# utilizador confirma que já estão prontas (secção 23). Tens de configurar o
# bucket para aceitar estes 3 mime types (application/pdf, image/jpeg, image/png).
SUPABASE_STORAGE_BUCKET=documentos

# Crawler / subscrição
CRAWLER_CACHE_TTL_HOURS=48
GRACE_PERIOD_DAYS=5

# Chave usada pelo painel de super-admin (secção 12.4 — rotas /admin/*)
ADMIN_API_KEY=

PORT=3000
